---
import Layout from "../layouts/Layout.astro";

const videoModules = import.meta.glob<{ default: string }>(
  "../assets/video/*.mp4",
  { eager: true },
);
const videos = Object.values(videoModules).map((m) => m.default);
---

<Layout
  title='Lorezz'
  description='Lorezz is a full stack web developer.'
  showHeaders={false}
>
  <div
    id='video-background'
    class='relative w-full min-h-screen flex items-start md:items-center justify-center overflow-hidden'
  >
    <video
      id='bg-video'
      autoplay
      muted
      loop
      playsinline
      class='absolute inset-0 w-full h-full object-cover -z-10'></video>
    <section
      class='bg-base-300 card rounded-none md:rounded-lg flex flex-col items-center justify-center p-10 shadow-xl max-w-2xl w-full md:w-auto mx-0 md:mx-auto'
    >
      <div class='card-body items-center text-center'>
        <div class='mx-auto lg:mx-2'>
          <img
            src='logo.png'
            alt='Lorezz logo'
            loading='lazy'
            class='logo-spin max-w-[200px] mb-10'
            width='200px'
            height='200px'
          />
          <h1 class='invisible'>Lorezz</h1>
        </div>
        <div class='text-2xl font-bold mb-4'>Hi, I'm Lorenzo, aka Lorezz.</div>
        <div>
          <p class='mb-4'>
            I'm a Software Engineer, Open Source advocate, and tech enthusiast
            with a deep love for the natural world.
          </p>
          <p class='mb-4'>
            My work and interests focus on AI, IoT, and cutting-edge
            technologies, always viewed through a lens of sustainability and
            scientific curiosity.
          </p>
          <p class='mb-4'>
            Off-duty, I'm a maker and an explorer. Whether I'm crafting DIY
            projects with 3D printing and raw materials like wood and iron,
            flying drones, or hitting the trails on my motorbike, I thrive where
            technology and the great outdoors collide.
          </p>
          <p class='mb-4'>
            You can write me an email at <a
              target='_blank'
              href='mailto:lorezz@lorezz.net'
              class='transition-all duration-200 ease-[cubic-bezier(0.42,0,0.58,1)] cursor-pointer no-underline text-white hover:text-[#86c9f0] hover:no-underline hover:outline-none focus:outline-none focus:text-white active:outline-none active:text-white'
              >lorezz@lorezz.net</a
            >
          </p>
        </div>
        <p class='mb-4'>Or you can find me on the following socials</p>
        <div class='flex items-center max-lg:justify-center'>
          <a
            href='https://github.com/lorezz'
            class='mr-[10px] transition-all duration-200 ease-[cubic-bezier(0.42,0,0.58,1)] cursor-pointer no-underline text-white hover:text-[#86c9f0]'
          >
            <span class='text-[32px] text-white'>
              <i class='fab fa-github-square'></i>
            </span></a
          >
          <a
            href='https://twitter.com/wisejerk'
            class='mr-[10px] transition-all duration-200 ease-[cubic-bezier(0.42,0,0.58,1)] cursor-pointer no-underline text-white hover:text-[#86c9f0]'
          >
            <span class='text-[32px] text-white'>
              <i class='fab fa-twitter-square'></i>
            </span>
          </a>
          <a
            href='https://www.linkedin.com/in/lorenzoponticelli'
            class='mr-[10px] transition-all duration-200 ease-[cubic-bezier(0.42,0,0.58,1)] cursor-pointer no-underline text-white hover:text-[#86c9f0]'
          >
            <span class='text-[32px] text-white'>
              <i class='fab fa-linkedin'></i>
            </span>
          </a>
          <a
            href='https://medium.com/@lorezz'
            class='mr-[10px] transition-all duration-200 ease-[cubic-bezier(0.42,0,0.58,1)] cursor-pointer no-underline text-white hover:text-[#86c9f0]'
          >
            <span class='text-[32px] text-white'>
              <i class='fab fa-medium'></i>
            </span>
          </a>
        </div>
        <div class='text-xs mt-2'>
          {new Date().getFullYear()} © Lorezz
        </div>
      </div>
    </section>
  </div>
</Layout>

<script is:inline define:vars={{ videos }}>
  const isMobile = window.matchMedia("(max-width: 768px)").matches;

  if (!isMobile) {
    const video = document.getElementById("bg-video");
    video.muted = true;

    const shuffled = [...videos].sort(() => Math.random() - 0.5);
    let index = 0;
    let timer = null;

    function playNext() {
      clearTimeout(timer);
      video.src = shuffled[index % shuffled.length];
      index++;
      video.play();
      timer = setTimeout(playNext, 30000);
    }

    playNext();
  }
</script>

<style>
  @keyframes spin {
    to {
      transform: rotate(-360deg);
    }
  }

  .logo-spin {
    animation: spin 8s linear infinite;
    transform-origin: center;
    transition: animation-duration 0.6s ease;
  }

  .logo-spin:hover {
    animation-duration: 0.3s;
  }
</style>
